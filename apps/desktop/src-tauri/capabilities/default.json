{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default SayNext desktop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-center",
    "core:window:allow-set-position",
    "clipboard-manager:allow-write-text",
    "global-shortcut:default",
    "autostart:default"
  ]
}
