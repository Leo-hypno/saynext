{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SayNext",
  "version": "0.1.6",
  "identifier": "dev.saynext.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SayNext",
        "label": "main",
        "width": 620,
        "height": 620,
        "minWidth": 420,
        "minHeight": 460,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2MEI1OEUxMzE3OTU3MzgKUldRNFYza3g0VmdMaGtLcmVETy9jZUxSYWhaWXpRRGtJOG0rMVptcEM1MkFTLzFCUUFsbWdwYUMK",
      "endpoints": [
        "https://github.com/Leo-hypno/saynext/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
