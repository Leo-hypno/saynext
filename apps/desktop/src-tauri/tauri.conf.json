{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SayNext",
  "version": "0.1.0",
  "identifier": "dev.saynext.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SayNext",
        "label": "main",
        "width": 620,
        "height": 620,
        "minWidth": 420,
        "minHeight": 460,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
