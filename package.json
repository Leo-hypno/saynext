{
  "name": "saynext",
  "private": true,
  "version": "0.1.7",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "dev": "npm --workspace apps/desktop run dev",
    "dev:web": "npm --workspace apps/desktop run dev:web",
    "build": "npm --workspace apps/desktop run build",
    "bundle": "npm --workspace apps/desktop run tauri:build",
    "typecheck": "npm --workspace apps/desktop run typecheck",
    "cargo:check": "cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "validate:packs": "node scripts/validate-packs.mjs",
    "version:set": "node scripts/set-version.mjs",
    "make:icon": "node scripts/make-icon.mjs",
    "check": "npm run validate:packs && npm run typecheck && npm run build && npm run cargo:check"
  }
}
